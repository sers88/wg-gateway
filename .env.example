# wg-gateway configuration
# Copy this file to .env and modify as needed.

# --- WireGuard (wg-easy) ---
# Public IP or hostname of this server (REQUIRED for client config generation)
WG_HOST=your-server-public-ip
# WireGuard server UDP port
WG_PORT=51820
# DNS servers advertised to WireGuard clients
# With Mihomo dns-hijack active, any DNS will be intercepted
WG_DEFAULT_DNS=1.1.1.1
# Routes advertised to clients (0.0.0.0/0 = all traffic through the gateway)
WG_ALLOWED_IPS=0.0.0.0/0,::/0
# Keepalive interval in seconds
WG_PERSISTENT_KEEPALIVE=25
# wg-easy Web UI port
WG_EASY_PORT=51821
# Password hash for wg-easy UI (bcrypt hash, NOT plaintext).
# Generate one with: docker run -it ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
# Copy the output hash (including the $2b$... prefix) here.
WG_EASY_PASSWORD=

# --- Proxy Engine (Mihomo) ---
# External controller / Web UI port
MIHOMO_PORT=51888
# Optional secret for the external controller API
MIHOMO_SECRET=
# Custom iptables POST_UP (leave empty for gateway default: FORWARD-only, no MASQUERADE)
WG_POST_UP=
# Custom iptables POST_DOWN
WG_POST_DOWN=

# --- General ---
TZ=UTC
